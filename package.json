{
  "name": "wordpress-theme",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"wp-scripts start\"",
    "build": "vite build && wp-scripts build",
    "package": "npm run build && node package-theme.js",
    "package:zip": "npm run build && node package-theme.js --zip",
    "link": "node symlink.js",
    "unlink": "node symlink.js --remove",
    "clean": "rm -rf node_modules release build dist && echo 'cleaned'"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@wordpress/scripts": "^31.6.0",
    "concurrently": "^9.2.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "gsap": "^3.14.2",
    "tailwindcss": "^4.2.1"
  }
}
